  remotePrice Float   @default(0)

  rippleTapePrice Float @default(0)
  totalPrice      Float @default(0)

  // ✅ ADD THESE 3 NEW FIELDS
  trackFinal      Float @default(0)
  motorFinal      Float @default(0)
  remoteFinal     Float @default(0)
}

